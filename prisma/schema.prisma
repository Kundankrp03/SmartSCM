// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id            String             @id @default(uuid())
  sku           String             @unique
  name          String
  description   String?
  category      String
  price         Float
  stockLevel    Int
  minStockLevel Int                // Reorder point (low stock trigger)
  maxStockLevel Int                // Target stock level
  supplierId    String?
  supplier      Supplier?          @relation(fields: [supplierId], references: [id])
  transactions  StockTransaction[]
  orderItems    OrderItem[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Supplier {
  id          String          @id @default(uuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  leadTime    Int             // Typical lead time in days
  rating      Float           // Rating out of 5
  products    Product[]
  orders      PurchaseOrder[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model StockTransaction {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type        String   // "IN" (restock), "OUT" (sales/depletion), "ADJUSTMENT" (manual correction)
  quantity    Int
  reason      String?  // e.g., "Sale", "Restock", "Damaged"
  performedBy String?  // User identifier
  createdAt   DateTime @default(now())
}

model PurchaseOrder {
  id                   String      @id @default(uuid())
  poNumber             String      @unique // e.g. PO-1001
  supplierId           String
  supplier             Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items                OrderItem[]
  status               String      // "DRAFT", "SENT", "SHIPPED", "DELIVERED", "CANCELLED"
  orderDate            DateTime    @default(now())
  expectedDeliveryDate DateTime?
  actualDeliveryDate   DateTime?
  totalAmount          Float
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model OrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int
  unitPrice       Float
}

model SystemAlert {
  id         String    @id @default(uuid())
  type       String    // "LOW_STOCK", "DELIVERY_DELAY", "FORECAST_SPIKE", "SYSTEM"
  severity   String    // "INFO", "WARNING", "CRITICAL"
  title      String
  message    String
  resolved   Boolean   @default(false)
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
}
